---
interface Props {
  year: string;
  title: string;
  description: string;
}

const { year, title, description } = Astro.props;
---

<article class="accomplishment-item">
  <span class="acc-year">{year}</span>
  <div class="acc-content">
    <strong>{title}</strong>
    <p>{description}</p>
  </div>
</article>

<style>
  .accomplishment-item {
    background: var(--surface);
    padding: 1.75rem 2rem;
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 2rem;
    align-items: baseline;
    transition: all 0.3s ease;
    border-left: 3px solid var(--accent);
    border-radius: 0.375rem;
  }

  .accomplishment-item:hover {
    background: var(--surface-elevated);
    box-shadow: 0 6px 20px rgba(6, 182, 212, 0.1);
    transform: translateX(4px);
  }

  .acc-year {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: bold;
  }

  .acc-content strong {
    display: block;
    font-size: 1rem;
    color: var(--primary);
    margin-bottom: 0.25rem;
    text-transform: uppercase;
  }

  .acc-content p {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--secondary);
  }

  @media (max-width: 768px) {
    .accomplishment-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
