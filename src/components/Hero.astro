---
interface Props {
  name: string;
  role: string;
  bio: string;
}

const { name, role, bio } = Astro.props;
---

<section class="hero-section" id="hero" data-section="hero">
  <p class="hero-label">👋 Welcome</p>
  <h1 class="hero-name">{name}</h1>
  <div class="hero-role">
    <span class="role-marker">+</span>
    <span class="role-text">{role}</span>
  </div>
  <p class="hero-objective">{bio}</p>
</section>

<style>
  .hero-section {
    margin-bottom: 6rem;
    border-left: 3px solid var(--accent);
    padding-left: 2.5rem;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .hero-name {
    font-size: 5.5rem;
    line-height: 0.95;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-role {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    background: var(--accent-dim);
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--accent);
    border-radius: 0.375rem;
  }

  .role-marker {
    color: var(--accent);
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .role-text {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--primary);
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .hero-objective {
    font-size: 1.05rem;
    color: var(--secondary);
    max-width: 650px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  @media (max-width: 1024px) {
    .hero-name {
      font-size: 3.5rem;
    }

    .hero-objective {
      font-size: 1rem;
    }
  }

  @media (max-width: 768px) {
    .hero-name {
      font-size: 2.5rem;
    }
  }
</style>
