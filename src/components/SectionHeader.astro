---
interface Props {
  number: string;
  title: string;
  status?: string;
}

const { number, title, status } = Astro.props;
---

<div class="section-header">
  <span class="section-number">{number}</span>
  <h2 class="section-title">{title}</h2>
  {status && <span class="section-status">{status}</span>}
</div>

<style>
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--accent);
    opacity: 0.3;
  }

  .section-number {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 700;
    background: var(--accent-dim);
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
  }

  .section-title {
    font-size: 2.75rem;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: var(--primary);
  }

  .section-status {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    margin-left: auto;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 1024px) {
    .section-header {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .section-title {
      font-size: 2rem;
    }

    .section-status {
      width: 100%;
      margin-left: 3rem;
      margin-top: -0.5rem;
    }
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 1.5rem;
    }
  }
</style>
