<aside class="sidebar">
  <div class="sidebar-inner">
    <div class="profile-block">
      <img src="/avatar.jpg" alt="Ruchir Kalokhe" class="profile-avatar" />
      <div class="profile-meta">
        <div class="profile-path">
          <span class="path-dim">/home/</span><span class="path-name">ruchir</span>
        </div>
      </div>
    </div>

    <nav class="sidebar-nav">
      <a href="#hero" class="nav-link">Profile</a>
      <a href="#experience" class="nav-link">Experience</a>
      <a href="#projects" class="nav-link">Projects</a>
      <a href="#accomplishments" class="nav-link">Accomplishments</a>
      <a href="#education" class="nav-link">Education</a>
    </nav>
  </div>

  <div class="sidebar-links">
    <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="sidebar-link">
      <i class="fab fa-github"></i> GitHub
    </a>
    <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="sidebar-link">
      <i class="fab fa-linkedin"></i> LinkedIn
    </a>
    <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="sidebar-link">
      <i class="fab fa-twitter"></i> Twitter
    </a>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    background: linear-gradient(180deg, var(--surface) 0%, var(--surface-elevated) 100%);
    border-right: 1px solid var(--border);
    padding: 2.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    height: 100%;
  }

  .profile-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .profile-avatar {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 0.5rem;
    border: 2px solid var(--accent);
    object-fit: cover;
    transition: all 0.3s ease;
  }

  .profile-avatar:hover {
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.3);
  }

  .profile-meta {
    font-family: var(--font-mono);
  }

  .profile-path {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .path-dim {
    color: var(--muted);
  }

  .path-name {
    color: var(--accent);
    font-weight: 700;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 600;
    transition: all 0.3s ease;
    padding-left: 0.75rem;
    border-left: 2px solid transparent;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
  }

  .nav-link:hover {
    color: var(--accent);
    border-left-color: var(--accent);
    padding-left: 1.25rem;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: auto;
  }

  .sidebar-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: all 0.2s ease;
  }

  .sidebar-link:hover {
    color: var(--accent);
  }
</style>
