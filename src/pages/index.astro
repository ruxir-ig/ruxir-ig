---
import Base from '../layouts/Base.astro';
---

<Base title="Home">

  <!-- ═══ HERO — THE OPENING SHOT ═══ -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/hero.png" alt="" aria-hidden="true" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content container">
      <div class="hero-meta hero-animate" style="--delay: 0">
        <span class="status-dot"></span>
        <span>Pune, India</span>
      </div>
      <h1 class="hero-name">
        <span class="hero-animate" style="--delay: 1">Ruchir</span>
        <span class="hero-animate" style="--delay: 2">Kalokhe</span>
      </h1>
      <p class="hero-role hero-animate" style="--delay: 3">Backend Engineer & AI Research Enthusiast</p>
      <p class="hero-sub hero-animate" style="--delay: 4">
        Building ML infrastructure and backend systems<br class="hide-mobile" />
        while moving deeper into AI research.
      </p>
      <div class="hero-cta hero-animate" style="--delay: 5">
        <a href="/work" class="btn-ghost">View Work</a>
        <a href="mailto:ruchirkalokhe@gmail.com" class="btn-ghost">Get in Touch</a>
      </div>
    </div>
    <div class="hero-scroll hero-animate" style="--delay: 6">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>


  <!-- ═══ ABOUT — THE PULL QUOTE ═══ -->
  <section class="section about-section">
    <div class="container">
      <div data-reveal>
        <span class="section-label">01 — About</span>
      </div>

      <div class="about-grid">
        <blockquote class="about-quote" data-reveal style="--stagger: 1">
          "I like building things that sit somewhere between ML, web engineering, and developer tooling."
        </blockquote>

        <div class="about-details" data-reveal style="--stagger: 2">
          <div class="detail-item">
            <span class="detail-label">Currently</span>
            <span class="detail-value">Gen AI Intern @ In2peta</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Education</span>
            <span class="detail-value">B.E. in AI & Data Science</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">University</span>
            <span class="detail-value">PES Modern College, Pune</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Focus</span>
            <span class="detail-value">ML Infra · Backend · Systems</span>
          </div>
        </div>
      </div>

      <p class="about-body" data-reveal style="--stagger: 3">
        Most of my learning has come from experimenting, shipping side projects, breaking systems,
        and working through the small deployment and product details until they feel right.
        I work across model serving, GPU inference, backend architecture, and the operational details
        that make AI systems actually work in production.
      </p>

      <div class="about-skills" data-reveal style="--stagger: 4">
        <span class="tag">Python</span>
        <span class="tag">TypeScript</span>
        <span class="tag">PyTorch</span>
        <span class="tag">TensorFlow</span>
        <span class="tag">Fastify</span>
        <span class="tag">Docker</span>
        <span class="tag">PostgreSQL</span>
        <span class="tag">Redis</span>
        <span class="tag">Prisma</span>
        <span class="tag">BullMQ</span>
        <span class="tag">SGLang</span>
        <span class="tag">Linux</span>
        <span class="tag">CI/CD</span>
        <span class="tag">Modal</span>
      </div>
    </div>
  </section>


  <!-- ═══ SELECTED WORK ═══ -->
  <section class="section work-preview">
    <div class="container">
      <div data-reveal>
        <span class="section-label">02 — Selected Work</span>
        <h2 class="section-title">Beyond the Terminal.</h2>
      </div>

      <div class="work-grid">
        <a href="/work" class="work-card work-card--featured" data-reveal style="--stagger: 1">
          <div class="work-card-inner">
            <div class="work-card-tags">
              <span class="tag tag--accent">Platform</span>
              <span class="tag">BFS</span>
              <span class="tag">Anomaly Detection</span>
            </div>
            <h3 class="work-card-title">TraceLink</h3>
            <p class="work-card-desc">Supply chain traceability platform with contaminated-batch tracing,
              entropy-based anomaly detection, and probabilistic imputation for incomplete records.</p>
            <span class="work-card-link">View Project →</span>
          </div>
        </a>

        <a href="/work" class="work-card" data-reveal style="--stagger: 2">
          <div class="work-card-inner">
            <div class="work-card-tags">
              <span class="tag tag--cold">API</span>
              <span class="tag">GPU Inference</span>
            </div>
            <h3 class="work-card-title">MuseTalk API</h3>
            <p class="work-card-desc">REST API for real-time talking-head video generation.
              1.8× inference throughput improvement via GFPGAN pipeline optimization.</p>
            <span class="work-card-link">View Project →</span>
          </div>
        </a>

        <a href="/work" class="work-card" data-reveal style="--stagger: 3">
          <div class="work-card-inner">
            <div class="work-card-tags">
              <span class="tag tag--sage">Research</span>
              <span class="tag">GANs</span>
            </div>
            <h3 class="work-card-title">SAR Colorization</h3>
            <p class="work-card-desc">GAN-based model to colorize grayscale SAR satellite imagery.
              Encoder-decoder experiments for terrain reconstruction. Top 25 SIH 2024.</p>
            <span class="work-card-link">View Project →</span>
          </div>
        </a>
      </div>

      <div class="work-cta" data-reveal style="--stagger: 4">
        <a href="/work" class="btn-ghost">All Projects & Career →</a>
      </div>
    </div>
  </section>

</Base>


<style>
  /* ─── HERO ─── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: saturate(0.5) contrast(1.1);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(17, 17, 16, 0.3) 0%,
      rgba(17, 17, 16, 0.6) 50%,
      rgba(17, 17, 16, 1) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 120px;
    padding-bottom: 80px;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-label);
    font-weight: var(--text-label-weight);
    letter-spacing: var(--text-label-ls);
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: var(--space-6);
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(56px, 10vw, 120px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--space-8);
  }

  .hero-name span {
    display: block;
  }

  .hero-role {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent-primary);
    margin-bottom: var(--space-6);
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--text-secondary);
    max-width: 480px;
    margin-bottom: var(--space-10);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-4);
  }

  /* Hero staggered entrance - page load animation */
  .hero-animate {
    opacity: 0;
    transform: translateY(24px);
    animation: hero-reveal 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    animation-delay: calc(var(--delay) * 120ms + 200ms);
  }

  @keyframes hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    bottom: 40px;
    right: var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    z-index: 1;
  }

  .hero-scroll span {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-ghost);
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--text-ghost), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 1; transform: scaleY(1); }
    50% { opacity: 0.3; transform: scaleY(0.6); }
  }


  /* ─── ABOUT ─── */
  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
    align-items: start;
  }

  .about-quote {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.35;
    color: var(--text-primary);
    border-left: 2px solid var(--accent-primary);
    padding-left: var(--space-8);
    margin: 0;
  }

  .about-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-top: var(--space-2);
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .detail-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    font-weight: var(--text-label-weight);
    letter-spacing: var(--text-label-ls);
    text-transform: uppercase;
    color: var(--text-ghost);
  }

  .detail-value {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--text-secondary);
  }

  .about-body {
    font-size: var(--text-body-lg);
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 720px;
    margin-bottom: var(--space-10);
  }

  .about-skills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }


  /* ─── WORK PREVIEW ─── */
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .work-card {
    display: block;
    text-decoration: none;
    background: var(--surface-raised);
    border: 1px solid var(--border-default);
    padding: var(--space-8);
    transition: transform 300ms cubic-bezier(0.23, 1, 0.32, 1),
                border-color 300ms cubic-bezier(0.23, 1, 0.32, 1),
                box-shadow 300ms cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
    overflow: hidden;
  }

  .work-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, var(--accent-primary), transparent);
    opacity: 0;
    transition: opacity 300ms ease;
  }

  .work-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .work-card:hover::before { opacity: 1; }

  .work-card:active {
    transform: translateY(-1px) scale(0.995);
  }

  .work-card--featured {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, var(--surface-raised) 0%, var(--surface-dim) 100%);
  }

  .work-card-tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .work-card-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }

  .work-card-desc {
    font-size: var(--text-body-sm);
    color: var(--text-tertiary);
    max-width: 560px;
    margin-bottom: var(--space-5);
  }

  .work-card-link {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--text-label-ls);
    text-transform: uppercase;
    color: var(--accent-primary);
    transition: color 0.2s ease;
  }

  .work-card:hover .work-card-link { color: var(--accent-primary-hover); }

  .work-cta {
    text-align: center;
    padding-top: var(--space-4);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .hero-content { padding-top: 100px; }
    .hero-cta { flex-direction: column; }
    .hero-cta .btn-ghost { text-align: center; }
    .about-grid { grid-template-columns: 1fr; gap: var(--space-8); }
    .work-grid { grid-template-columns: 1fr; }
    .work-card--featured { grid-column: auto; }
    .hero-scroll { display: none; }
  }
</style>
